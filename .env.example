# Server Configuration
HOST=localhost
PORT=3000

# neon-db
DATABASE_URL=postgresql://example:example@example/neondb?channel_binding=require&sslmode=verify-full

# JWT Token
ACCESS_TOKEN_KEY= # Generate it yourself using this on terminal : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
REFRESH_TOKEN_KEY= # Generate it yourself using this on terminal : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

